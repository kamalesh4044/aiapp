{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aura/event-envelope/v1",
  "title": "AURA Event Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "trace_id",
    "actor",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F-]{36}$"
    },
    "event_type": {
      "type": "string",
      "minLength": 3
    },
    "event_version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 8
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "device", "service"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "payload": {
      "type": "object"
    }
  }
}
